{{<html}}
{{$main}}

<div id="not-found" class="page">
    {{& page.contents.html}}
</div>

<script>
(function () {
    var path = window.location.pathname;

    // Exact-match redirect table (case-insensitive).
    // Covers legacy URLs that do not have dedicated redirect pages
    // (typically lowercase variants of slugs whose uppercase equivalents
    // already have redirect pages generated by the site build).
    var exact = {
        '/cvbuilder':                       '/blog/c-v-builder/',
        '/cvbuilder/':                      '/blog/c-v-builder/',
        '/c-v-page':                        '/blog/c-v-builder/',
        '/extremepackaging':                '/blog/extreme-packaging/',
        '/extremepackaging/':               '/blog/extreme-packaging/',
        '/extremepackagingopenapi':         '/blog/extreme-packaging-open-a-p-i/',
        '/extremepackagingopenapi/':        '/blog/extreme-packaging-open-a-p-i/',
        '/coreanimation3dcube':             '/blog/core-animation-3d-cube/',
        '/coreanimation3dcube/':            '/blog/core-animation-3d-cube/',
        '/core-animation-layers-forming-a-3d-cube': '/blog/core-animation-3d-cube/',
        '/tokenmiddeware':                  '/blog/token-middleware/',
        '/tokenmiddeware/':                 '/blog/token-middleware/',
        '/tokenmiddleware':                 '/blog/token-middleware/',
        '/tokenmiddleware/':                '/blog/token-middleware/',
        '/loggingmiddleware':               '/blog/logging-middleware/',
        '/loggingmiddleware/':              '/blog/logging-middleware/',
        '/swiftuilabadvancedanimations':    '/blog/swift-u-i-lab-advanced-animations/',
        '/swiftuilabadvancedanimations/':   '/blog/swift-u-i-lab-advanced-animations/',
        '/cupertino':                       '/cupertino/',
        '/cupertino/null':                  '/cupertino/',
        '/blog/cupertino-ins':              '/blog/cupertino-instant-setup/',
        '/home':                            '/',
        '/home/':                           '/'
    };

    var lower = path.toLowerCase();
    var qs = window.location.search || '';
    var hash = window.location.hash || '';

    if (exact.hasOwnProperty(lower)) {
        window.location.replace(exact[lower] + qs + hash);
        return;
    }

    // Prefix redirects for dynamic legacy URL patterns (Ghost CMS, old tag systems).
    var prefixMap = [
        ['/tag/',     '/'],
        ['/tags/',    '/'],
        ['/author/',  '/about/'],
        ['/p/',       '/'],
        ['/posts/',   '/blog/'],
        ['/read/',    '/']
    ];
    for (var i = 0; i < prefixMap.length; i++) {
        if (lower.indexOf(prefixMap[i][0]) === 0) {
            window.location.replace(prefixMap[i][1] + qs + hash);
            return;
        }
    }
})();
</script>

{{/main}}
{{/html}}
